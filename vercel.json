{
  "routes": [
    { "src": "/api/forecast",   "dest": "/api/index.py" },
    { "src": "/api/cron",       "dest": "/api/index.py" },
    { "src": "/api/cron-run",   "dest": "/api/index.py" },
    { "src": "/api/auth/(.*)",  "dest": "/api/index.py" },
    { "src": "/api/admin/(.*)", "dest": "/api/index.py" },
    { "src": "/",               "dest": "/index.html"   },
    { "src": "/(.*)",           "dest": "/index.html"   }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 * * * *"
    }
  ]
}