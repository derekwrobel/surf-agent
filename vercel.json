{
  "routes": [
    { "src": "/api/forecast", "dest": "/api/index.py" },
    { "src": "/api/cron",     "dest": "/api/cron.py"  },
    { "src": "/",             "dest": "/index.html"   },
    { "src": "/(.*)",         "dest": "/index.html"   }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 * * * *"
    }
  ]
}
